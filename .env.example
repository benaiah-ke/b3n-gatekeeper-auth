APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
GATEKEEPER_URL=http://localhost:8000
UI_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

DATABASE_URL=postgresql+asyncpg://gatekeeper:gatekeeper@localhost:54329/gatekeeper
TEST_DATABASE_URL=sqlite+aiosqlite:///./test_gatekeeper.db

SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_KEY_ID=local-dev
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
DEVICE_CODE_TTL_SECONDS=600
EMAIL_CODE_TTL_SECONDS=900

BOOTSTRAP_ADMIN_EMAIL=admin@b3n.in
BOOTSTRAP_ORG_NAME=B3n
BOOTSTRAP_ORG_SLUG=b3n

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=GateKeeper <auth@gatekeeper.b3n.in>
SMTP_USE_TLS=true
EMAIL_DEV_MODE=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

ENABLE_DYNAMIC_CLIENT_REGISTRATION=false
MCP_DEFAULT_SCOPES=mcp:tools,mcp:resources

