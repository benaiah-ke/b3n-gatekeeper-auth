APP_ENV=production
APP_VERSION=0.1.0
DEBUG=false
GATEKEEPER_API_IMAGE=gatekeeper-api
GATEKEEPER_UI_IMAGE=gatekeeper-ui
GATEKEEPER_IMAGE_TAG=latest
GATEKEEPER_URL=https://auth.example.com
UI_URL=https://auth.example.com
CORS_ORIGINS=https://auth.example.com

DATABASE_URL=postgresql+asyncpg://gatekeeper:change-me@gatekeeper-postgres:5432/gatekeeper
POSTGRES_DB=gatekeeper
POSTGRES_USER=gatekeeper
POSTGRES_PASSWORD=change-me

SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_KEY_DIR=/data/keys
JWT_KEY_ID=gatekeeper-prod
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
DEVICE_CODE_TTL_SECONDS=600
EMAIL_CODE_TTL_SECONDS=900

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ORG_NAME=Example Org
BOOTSTRAP_ORG_SLUG=example

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=GateKeeper <auth@example.com>
SMTP_USE_TLS=true
EMAIL_DEV_MODE=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://auth.example.com/api/v1/auth/oauth/google/callback
OAUTH_PROVIDERS_JSON=

ENABLE_DYNAMIC_CLIENT_REGISTRATION=false
MCP_DEFAULT_SCOPES=mcp:tools,mcp:resources

COOKIE_NAME=gk_session
REFRESH_COOKIE_NAME=gk_refresh
DEVICE_COOKIE_NAME=gk_device
COOKIE_SECURE=true
COOKIE_DOMAIN=

TLS_EMAIL=admin@example.com
DEFAULT_DOMAIN=auth.example.com
GATEKEEPER_ENV_FILE=.env
